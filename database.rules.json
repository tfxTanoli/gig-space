{
  "rules": {
    "users": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth !== null",
        ".write": "auth !== null && ((auth.uid === $uid && (!newData.hasChild('role') || newData.child('role').val() !== 'admin')) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth !== null && ((newData.exists() && newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)) || (!newData.exists() && (!data.exists() || data.val() === auth.uid)))"
      }
    },
    "services": {
      ".read": true,
      ".indexOn": ["sellerId", "createdAt"],
      "$postId": {
        ".write": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() ? newData.child('sellerId').val() === auth.uid : data.child('sellerId').val() === auth.uid))"
      }
    },
    "conversations": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["buyerId", "sellerId"],
      "$conversationId": {
        ".read": "auth !== null && (!data.exists() || data.child('buyerId').val() === auth.uid || data.child('sellerId').val() === auth.uid)",
        ".write": "auth !== null && (!data.exists() || data.child('buyerId').val() === auth.uid || data.child('sellerId').val() === auth.uid)"
      }
    },
    "messages": {
      "$conversationId": {
        ".read": "auth !== null && (root.child('conversations').child($conversationId).child('buyerId').val() === auth.uid || root.child('conversations').child($conversationId).child('sellerId').val() === auth.uid)",
        ".write": "auth !== null && (root.child('conversations').child($conversationId).child('buyerId').val() === auth.uid || root.child('conversations').child($conversationId).child('sellerId').val() === auth.uid)"
      }
    },
    "userConversations": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null"
      }
    },
    "orders": {
      ".indexOn": ["buyerId", "sellerId", "serviceId"],
      ".read": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'buyerId' && query.equalTo === auth.uid) || (query.orderByChild === 'sellerId' && query.equalTo === auth.uid) || (query.orderByChild === 'serviceId'))",
      "$orderId": {
        ".read": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('buyerId').val() === auth.uid || data.child('sellerId').val() === auth.uid)",
        ".write": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() ? newData.child('buyerId').val() === auth.uid : data.child('buyerId').val() === auth.uid || data.child('sellerId').val() === auth.uid))"
      }
    },
    "savedServices": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "orderMessages": {
      "$orderId": {
        ".read": "auth !== null && (root.child('orders').child($orderId).child('buyerId').val() === auth.uid || root.child('orders').child($orderId).child('sellerId').val() === auth.uid)",
        ".write": "auth !== null && (root.child('orders').child($orderId).child('buyerId').val() === auth.uid || root.child('orders').child($orderId).child('sellerId').val() === auth.uid)"
      }
    },
    "reviews": {
      "$orderId": {
        ".read": true,
        "buyerReview": {
          ".write": "auth !== null && root.child('orders').child($orderId).child('buyerId').val() === auth.uid && !data.exists()"
        },
        "sellerReview": {
          ".write": "auth !== null && root.child('orders').child($orderId).child('sellerId').val() === auth.uid && !data.exists() && root.child('reviews').child($orderId).child('buyerReview').exists()"
        }
      }
    },
    "userRatings": {
      "$uid": {
        ".read": true,
        ".write": "auth !== null && auth.uid !== $uid"
      }
    },
    "serviceReviews": {
      "$serviceId": {
        ".read": true,
        ".write": "auth !== null"
      }
    },

    "payments": {
      ".indexOn": ["buyerId", "sellerId", "orderId", "stripeSessionId", "stripePaymentIntentId"],
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$paymentId": {
        ".read": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('buyerId').val() === auth.uid || data.child('sellerId').val() === auth.uid)",
        ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "wallets": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": false
      }
    },

    "walletTransactions": {
      "$uid": {
        ".read": "auth !== null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": false
      }
    },

    "withdrawals": {
      ".indexOn": ["sellerId"],
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$withdrawalId": {
        ".read": "auth !== null && data.child('sellerId').val() === auth.uid",
        ".write": false
      }
    },

    "settings": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "affiliates": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "affiliateCodes": {
      "$code": {
        ".read": true,
        ".write": "auth !== null && newData.val() === auth.uid"
      }
    },

    "affiliateCommissions": {
      ".indexOn": ["affiliateId", "orderId"],
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$commissionId": {
        ".read": "auth !== null && data.child('affiliateId').val() === auth.uid",
        ".write": false
      }
    },

    "affiliateReferrals": {
      ".indexOn": ["affiliateId"],
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$referralId": {
        ".read": "auth !== null && data.child('affiliateId').val() === auth.uid",
        ".write": "auth !== null && newData.child('referredUserId').val() === auth.uid"
      }
    },

    "affiliatePayouts": {
      ".indexOn": ["affiliateId"],
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$payoutId": {
        ".read": "auth !== null && data.child('affiliateId').val() === auth.uid",
        ".write": false
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null"
      }
    },

    "notificationCounts": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null"
      }
    }
  }
}
