PORT=3001
FRONTEND_URL=http://localhost:5173

# Firebase — copy from your Firebase project settings
FIREBASE_DATABASE_URL=https://gigspace-208b4-default-rtdb.firebaseio.com

# Firebase service account key JSON file path
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Stripe — from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Optional: pre-create the $5/month extra-location price in your Stripe dashboard
# and paste its price ID here to skip the auto-create-and-cache flow.
# If omitted, the server creates the price once and caches it in Firebase at
# settings/stripe/extraLocationPriceId.
# STRIPE_EXTRA_LOCATION_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX
